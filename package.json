{
  "name": "custom-gift-sales-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --env-file-if-exists=.env --import tsx src/scripts/db-migrate.ts",
    "seed:agent": "node --env-file-if-exists=.env --import tsx src/scripts/seed-agent.ts",
    "telegram:poll": "node --env-file-if-exists=.env --import tsx src/scripts/telegram-poll.ts",
    "telegram:set-webhook": "node --env-file-if-exists=.env --import tsx src/scripts/telegram-set-webhook.ts",
    "embeddings:kb": "node --env-file-if-exists=.env --import tsx src/scripts/kb-embeddings.ts",
    "kb:import-notion": "node --env-file-if-exists=.env --import tsx src/scripts/import-notion-to-kb.ts"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
