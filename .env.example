# Deployment identity
APP_NAME=intellect-support-agent
APP_DOMAIN=example.your-domain.com

# Application
PORT=3000
NODE_ENV=production
TZ=Europe/Kyiv
LOG_LEVEL=info

# Traefik
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERTRESOLVER=cf

# PostgreSQL
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db

# OpenAI (AI consultant + embeddings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=20000
AI_CONTEXT_TOP_K=6
AI_AGENT_LANGUAGE=українська
AI_AGENT_NAME=Соня
SHOP_NAME=INTELLECT
AI_AGENT_SYSTEM_PROMPT_APPEND=

# Knowledge-base retrieval tuning
KB_VECTOR_THRESHOLD=0.45
KB_TRIGRAM_FLOOR=0.3
KB_CATEGORY_BOOST=1.25
FOLLOWUP_MAX_LEN=30

# Embedding worker
EMBEDDING_BATCH_SIZE=40
EMBEDDING_MAX_ITEMS=0
EMBEDDING_SLEEP_MS=50

# Admin KB panel (Basic auth). REQUIRED to enable /admin — leave empty to disable.
ADMIN_USER=
ADMIN_PASSWORD=

# ── Anti-spam / cost protection (abuse-guard) ──
MAX_INPUT_CHARS=1000
HARD_INPUT_CHARS=4000
RATE_BURST_10S=5
RATE_PER_MIN=15
RATE_PER_HOUR=120
RATE_PER_DAY=500
NEW_USER_AGE_MS=60000
NEW_USER_BURST_10S=3
REPEAT_FLOOD_N=3
LINK_SPAM_MAX=2
STRIKE_MUTE_1=3
STRIKE_MUTE_1_DURATION_MS=3600000
STRIKE_MUTE_2=5
STRIKE_MUTE_2_DURATION_MS=86400000
STRIKE_DECAY_MS=86400000
NOTICE_COOLDOWN_MS=3600000
DAILY_BUDGET_USD=5.00
DAILY_ANSWER_CAP=2000
BUDGET_CACHE_MS=30000
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
MODERATION_ENABLED=false
SWEEP_MS=300000
MAX_BODY_BYTES=1000000
OPENAI_PRICE_CHAT_INPUT_PER_1K=0.0004
OPENAI_PRICE_CHAT_OUTPUT_PER_1K=0.0016
OPENAI_PRICE_EMBED_PER_1K=0.00002

# Notion — ONLY for the one-time KB import (npm run kb:import-notion). Retire after.
NOTION_API_KEY=
NOTION_KB_DATABASE_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_TIMEOUT_MS=10000
TELEGRAM_LOCAL_WEBHOOK_URL=http://127.0.0.1:3000/webhooks/telegram
TELEGRAM_POLL_TIMEOUT_SEC=25
TELEGRAM_POLL_LIMIT=100
TELEGRAM_POLL_IDLE_MS=500
TELEGRAM_POLL_REQUEST_TIMEOUT_MS=30000
